---
import { getProductByAsin } from '../lib/amazon';

interface Props {
  asin: string;
  fallbackTitle?: string;
}

const { asin, fallbackTitle = '' } = Astro.props;
const product = await getProductByAsin(asin);
---

{product ? (
  <a href={product.detailUrl} rel="nofollow sponsored" target="_blank" class="amazon-card-link">
    <div class="amazon-card">
      <div class="amazon-card-info">
        <span class="amazon-card-badge">Amazon</span>
        <p class="amazon-card-title">{product.title}</p>
        <p class="amazon-card-price">{product.price}</p>
        <span class="amazon-card-btn">Amazonで見る →</span>
      </div>
      <div class="amazon-card-img">
        <img src={product.imageUrl} alt={product.title} loading="lazy" />
      </div>
    </div>
  </a>
) : (
  <div class="amazon-card-fallback">
    <a href={`https://www.amazon.co.jp/dp/${asin}?tag=${import.meta.env.AMAZON_PARTNER_TAG}`} rel="nofollow sponsored" target="_blank">
      {fallbackTitle || '商品をAmazonで見る'} →
    </a>
  </div>
)}

<style>
  .amazon-card-link {
    text-decoration: none;
    color: inherit;
    display: block;
    margin: 1.5rem 0;
  }
  .amazon-card {
    display: flex;
    align-items: center;
    border: 1px solid #ddd;
    border-radius: 12px;
    padding: 1rem 1.2rem;
    gap: 1rem;
    background: #fff;
    transition: box-shadow 0.2s;
  }
  .amazon-card:hover {
    box-shadow: 0 4px 16px rgba(0,0,0,0.1);
  }
  .amazon-card-info {
    flex: 1;
    min-width: 0;
  }
  .amazon-card-badge {
    display: inline-block;
    background: #232f3e;
    color: #ff9900;
    font-size: 0.7rem;
    font-weight: 700;
    padding: 2px 8px;
    border-radius: 4px;
    letter-spacing: 0.05em;
  }
  .amazon-card-title {
    font-size: 0.95rem;
    font-weight: 600;
    margin: 0.5rem 0 0.4rem;
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .amazon-card-price {
    font-size: 1.2rem;
    font-weight: 700;
    color: #b12704;
    margin: 0 0 0.5rem;
  }
  .amazon-card-btn {
    display: inline-block;
    background: #ff9900;
    color: #fff;
    font-size: 0.85rem;
    font-weight: 600;
    padding: 6px 16px;
    border-radius: 6px;
  }
  .amazon-card-img {
    flex-shrink: 0;
    width: 120px;
    height: 120px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .amazon-card-img img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }
  .amazon-card-fallback {
    margin: 1.5rem 0;
    text-align: center;
  }
  .amazon-card-fallback a {
    display: inline-block;
    background: #ff9900;
    color: #fff;
    padding: 10px 24px;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
  }
  @media (max-width: 480px) {
    .amazon-card {
      padding: 0.8rem;
    }
    .amazon-card-img {
      width: 90px;
      height: 90px;
    }
    .amazon-card-title {
      font-size: 0.85rem;
    }
    .amazon-card-price {
      font-size: 1rem;
    }
  }
</style>