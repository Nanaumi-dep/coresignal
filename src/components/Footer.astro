---
import { CATEGORIES } from "../lib/categories";
---

<footer class="border-t mt-20" style="background-color: var(--color-bg-secondary); border-color: var(--color-border);">
  <div class="max-w-6xl mx-auto px-4 py-12">
    <div class="flex flex-col md:flex-row justify-between gap-8">
      <div>
        <a href="/" class="text-lg font-black tracking-tight" style="color: var(--color-text-primary);">
          <span class="bg-gradient-to-r from-accent-blue to-accent-purple bg-clip-text text-transparent">Core</span>Signal
        </a>
        <p class="text-sm mt-2 max-w-xs" style="color: var(--color-text-muted);">
          エンジニアが運営するガジェット×クレカのメディア
        </p>
      </div>
      <div>
        <h3 class="text-sm font-semibold mb-3" style="color: var(--color-text-primary);">カテゴリ</h3>
        <ul class="space-y-2 text-sm">
          {CATEGORIES.map((cat) => (
            <li>
              <a
                href={`/${cat.slug}/`}
                class="transition-colors"
                style="color: var(--color-text-muted);"
              >
                {cat.name}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>
    <div class="border-t mt-8 pt-6 text-center text-xs" style="border-color: var(--color-border); color: var(--color-text-muted);">
      <div class="flex justify-center gap-4 mb-3">
        <a href="/about/" class="transition-colors hover:underline" style="color: var(--color-text-muted);">About</a>
        <a href="/contact/" class="transition-colors hover:underline" style="color: var(--color-text-muted);">お問い合わせ</a>
        <a href="/disclosure/" class="transition-colors hover:underline" style="color: var(--color-text-muted);">広告表記について</a>
        <a href="/privacy/" class="transition-colors hover:underline" style="color: var(--color-text-muted);">プライバシーポリシーについて</a>
      </div>
      <p>&copy; {new Date().getFullYear()} CoreSignal. All rights reserved.</p>
    </div>
  </div>
</footer>
