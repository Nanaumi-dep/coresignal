---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
  description: string;
  image?: string;
  type?: "website" | "article";
  date?: string;
  dateModified?: string;
  noindex?: boolean;
}

const {
  title,
  description,
  image = "/images/default-eyecatch.png",
  type = "website",
  date,
  dateModified,
  noindex = false,
} = Astro.props;

const siteTitle = "CoreSignal";
const pageTitle = title === siteTitle ? siteTitle : `${title} | ${siteTitle}`;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const imageURL = new URL(image, Astro.site);

// カテゴリ定義（パンくず用）
const categories: Record<string, { name: string; color: string }> = {
  gadget: { name: "ガジェット", color: "#e94560" },
  creditcard: { name: "クレジットカード", color: "#2196F3" },
  "desk-setup": { name: "デスクセットアップ", color: "#4ECDC4" },
  "dev-env": { name: "開発環境", color: "#7B2FBE" },
};

// JSON-LD構造化データ（XSS対策: < → \u003c）
function safeJsonLd(obj: unknown): string {
  return JSON.stringify(obj).replace(/</g, "\\u003c");
}

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: siteTitle,
  url: Astro.site?.toString(),
  inLanguage: "ja",
};

const blogPostingSchema = date
  ? {
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      headline: title,
      description,
      image: imageURL.toString(),
      datePublished: date,
      ...(dateModified && { dateModified }),
      inLanguage: "ja",
      mainEntityOfPage: {
        "@type": "WebPage",
        "@id": canonicalURL.toString(),
      },
    }
  : null;

const pathSegments = Astro.url.pathname.split("/").filter(Boolean);
const breadcrumbItems = [
  { "@type": "ListItem", position: 1, name: "ホーム", item: Astro.site?.toString() },
  ...pathSegments.map((segment, index) => ({
    "@type": "ListItem",
    position: index + 2,
    name: categories[segment]?.name || decodeURIComponent(segment),
    item: new URL(pathSegments.slice(0, index + 1).join("/") + "/", Astro.site!).toString(),
  })),
];

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: breadcrumbItems,
};
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    {noindex ? (
      <meta name="robots" content="noindex, nofollow" />
    ) : (
      <meta name="robots" content="index, follow" />
    )}
    <meta name="generator" content={Astro.generator} />

    {/* OGP */}
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={imageURL} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content={type} />
    <meta property="og:locale" content="ja_JP" />
    <meta property="og:site_name" content={siteTitle} />

    {/* Twitter Cards */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageURL} />

    {/* JSON-LD */}
    {type === "website" && (
      <script type="application/ld+json" set:html={safeJsonLd(websiteSchema)} />
    )}
    {blogPostingSchema && (
      <script type="application/ld+json" set:html={safeJsonLd(blogPostingSchema)} />
    )}
    <script type="application/ld+json" set:html={safeJsonLd(breadcrumbSchema)} />

    {/* テーマ初期化（フラッシュ防止のためインライン化） */}
    <script is:inline>
      (function() {
        var t;
        try { t = localStorage.getItem("theme"); } catch(e) {}
        if (t === "light" || t === "dark") {
          document.documentElement.setAttribute("data-theme", t);
        }
      })();
    </script>
  </head>
  <body class="min-h-screen flex flex-col" style="background-color: var(--color-bg); color: var(--color-text-primary);">
    <Header />

    <main class="flex-1">
      <slot />
    </main>

    <Footer />

    <script>
      import { initTheme } from "../scripts/theme.ts";
      initTheme();
    </script>
  </body>
</html>
