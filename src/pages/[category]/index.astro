---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ArticleCard from "../../components/ArticleCard.astro";
import { getCollection } from "astro:content";
import { CATEGORIES, CATEGORY_MAP, isValidCategory, getPostUrl } from "../../lib/categories";

export function getStaticPaths() {
  return CATEGORIES.map((cat) => ({
    params: { category: cat.slug },
    props: { category: cat },
  }));
}

const { category } = Astro.props;

if (!isValidCategory(category.slug)) {
  return Astro.redirect("/404");
}

const allPosts = await getCollection("posts");
const posts = allPosts
  .filter((p) => p.data.category === category.slug)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<BaseLayout
  title={`${category.name}の記事 | CoreSignal`}
  description={`CoreSignalの${category.name}に関する記事一覧。`}
>
  <div class="max-w-6xl mx-auto px-4 py-8">
    <div class="flex items-center gap-3 mb-8">
      <span
        class="inline-block w-1 h-8 rounded-full"
        style={`background-color: ${category.color};`}
      />
      <h1 class="text-2xl font-bold" style="color: var(--color-text-primary);">
        {category.name}
      </h1>
    </div>

    {/* カテゴリタブ */}
    <div class="flex flex-wrap gap-2 mb-8">
      {CATEGORIES.map((cat) => (
        <a
          href={`/${cat.slug}/`}
          class="px-4 py-2 text-sm font-medium rounded-lg border transition-all duration-200"
          style={
            cat.slug === category.slug
              ? `background-color: ${cat.color}; color: #ffffff; border-color: ${cat.color};`
              : `border-color: var(--color-border); color: var(--color-text-secondary); background-color: var(--color-surface);`
          }
        >
          {cat.name}
        </a>
      ))}
    </div>

    {posts.length > 0 ? (
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {posts.map((post) => (
          <ArticleCard
            href={getPostUrl(post)}
            title={post.data.title}
            date={post.data.date}
            eyecatch={post.data.eyecatch}
            categoryName={category.name}
            categoryColor={category.color}
          />
        ))}
      </div>
    ) : (
      <p class="py-12 text-center" style="color: var(--color-text-muted);">
        このカテゴリにはまだ記事がありません。
      </p>
    )}
  </div>
</BaseLayout>
