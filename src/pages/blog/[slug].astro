---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";

const categories: Record<string, { name: string; color: string }> = {
  gadget: { name: "ガジェット", color: "#e94560" },
  creditcard: { name: "クレジットカード", color: "#2196F3" },
  "desk-setup": { name: "デスクセットアップ", color: "#4ECDC4" },
  "dev-env": { name: "開発環境", color: "#7B2FBE" },
};

export async function getStaticPaths() {
  const posts = await getCollection("posts");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const cat = categories[post.data.category];
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  image={post.data.eyecatch}
  type="article"
  date={post.data.date}
  dateModified={post.data.dateModified}
>
  <article class="max-w-3xl mx-auto">
    <header class="mb-8">
      {cat && (
        <span class="text-xs font-medium px-2 py-1 rounded" style={`color: ${cat.color}; background: ${cat.color}20`}>
          {cat.name}
        </span>
      )}
      <h1 class="text-3xl md:text-4xl font-bold mt-3 mb-4">{post.data.title}</h1>
      <div class="flex items-center gap-4 text-text-muted text-sm">
        <time datetime={post.data.date}>公開: {post.data.date}</time>
        {post.data.dateModified && (
          <time datetime={post.data.dateModified}>更新: {post.data.dateModified}</time>
        )}
      </div>
      {post.data.tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mt-4">
          {post.data.tags.map((tag: string) => (
            <span class="text-xs bg-bg-hover text-text-muted px-2 py-1 rounded">#{tag}</span>
          ))}
        </div>
      )}
    </header>

    <img
      src={post.data.eyecatch}
      alt={`${post.data.title}のアイキャッチ画像`}
      class="w-full rounded-lg mb-8"
    />

    <div class="prose prose-invert max-w-none
      [&_h2]:text-2xl [&_h2]:font-bold [&_h2]:mt-10 [&_h2]:mb-4 [&_h2]:text-text
      [&_h3]:text-xl [&_h3]:font-semibold [&_h3]:mt-8 [&_h3]:mb-3 [&_h3]:text-text
      [&_p]:text-text [&_p]:leading-relaxed [&_p]:mb-4
      [&_a]:text-primary [&_a]:underline hover:[&_a]:opacity-80
      [&_ul]:list-disc [&_ul]:pl-6 [&_ul]:mb-4
      [&_ol]:list-decimal [&_ol]:pl-6 [&_ol]:mb-4
      [&_li]:text-text [&_li]:mb-1
      [&_code]:bg-bg-hover [&_code]:px-1.5 [&_code]:py-0.5 [&_code]:rounded [&_code]:text-sm
      [&_pre]:bg-bg-card [&_pre]:p-4 [&_pre]:rounded-lg [&_pre]:overflow-x-auto [&_pre]:mb-4
      [&_blockquote]:border-l-4 [&_blockquote]:border-primary [&_blockquote]:pl-4 [&_blockquote]:italic [&_blockquote]:text-text-muted
      [&_img]:rounded-lg [&_img]:my-4
    ">
      <Content />
    </div>

    {post.data.affiliate && (
      <p class="text-text-muted text-xs mt-8 border-t border-border pt-4">
        ※ この記事にはアフィリエイトリンクが含まれています。リンク先での購入により、当サイトが報酬を受け取る場合があります。
      </p>
    )}
  </article>
</BaseLayout>
