---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ArticleCard from "../../components/ArticleCard.astro";
import { getCollection, render } from "astro:content";

const categories: Record<string, { name: string; color: string }> = {
  gadget: { name: "ガジェット", color: "#e94560" },
  creditcard: { name: "クレジットカード", color: "#2196F3" },
  "desk-setup": { name: "デスクセットアップ", color: "#4ECDC4" },
  "dev-env": { name: "開発環境", color: "#7B2FBE" },
};

export async function getStaticPaths() {
  const posts = await getCollection("posts");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
const cat = categories[post.data.category];

// 目次生成（h2・h3のみ）
const toc = headings.filter((h) => h.depth === 2 || h.depth === 3);

// 関連記事（同カテゴリから最大3本、自分を除く）
const allPosts = await getCollection("posts");
const relatedPosts = allPosts
  .filter((p) => p.data.category === post.data.category && p.id !== post.id)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  image={post.data.eyecatch}
  type="article"
  date={post.data.date}
  dateModified={post.data.dateModified}
>
  <article class="max-w-3xl mx-auto px-4 py-8">
    {/* ヘッダー */}
    <header class="mb-8">
      <div class="flex items-center gap-3 mb-4">
        {cat && (
          <span
            class="text-xs font-bold px-3 py-1 rounded-md"
            style={`color: ${cat.color}; background: ${cat.color}18; border: 1px solid ${cat.color}40;`}
          >
            {cat.name}
          </span>
        )}
      </div>
      <h1 class="text-2xl md:text-3xl font-bold leading-tight mb-4" style="color: var(--color-text-primary);">
        {post.data.title}
      </h1>
      <div class="flex items-center gap-4 text-sm" style="color: var(--color-text-muted);">
        <time datetime={post.data.date}>公開: {post.data.date}</time>
        {post.data.dateModified && (
          <time datetime={post.data.dateModified}>更新: {post.data.dateModified}</time>
        )}
      </div>
      {post.data.tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mt-4">
          {post.data.tags.map((tag: string) => (
            <span
              class="text-xs px-2 py-1 rounded"
              style="background-color: var(--color-bg-secondary); color: var(--color-text-muted);"
            >
              #{tag}
            </span>
          ))}
        </div>
      )}
    </header>

    {/* アイキャッチ */}
    <img
      src={post.data.eyecatch}
      alt={`${post.data.title}のアイキャッチ画像`}
      class="w-full rounded-xl mb-8"
    />

    {/* 目次 */}
    {toc.length > 0 && (
      <nav
        class="rounded-xl p-5 mb-10 border"
        style="background-color: var(--color-bg-secondary); border-color: var(--color-border);"
        aria-label="目次"
      >
        <h2 class="text-sm font-bold mb-3" style="color: var(--color-text-primary);">目次</h2>
        <ul class="space-y-1.5 text-sm">
          {toc.map((heading) => (
            <li style={heading.depth === 3 ? "padding-left: 1rem;" : ""}>
              <a
                href={`#${heading.slug}`}
                class="transition-colors"
                style="color: var(--color-text-secondary);"
              >
                {heading.text}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    )}

    {/* 本文 */}
    <div class="prose-article">
      <Content />
    </div>

    {/* アフィリエイト開示 */}
    {post.data.affiliate && (
      <p
        class="text-xs mt-8 border-t pt-4"
        style="color: var(--color-text-muted); border-color: var(--color-border);"
      >
        ※ この記事にはアフィリエイトリンクが含まれています。リンク先での購入により、当サイトが報酬を受け取る場合があります。
      </p>
    )}
  </article>

  {/* 関連記事 */}
  {relatedPosts.length > 0 && (
    <section class="max-w-3xl mx-auto px-4 pb-16">
      <div class="border-t pt-10" style="border-color: var(--color-border);">
        <h2 class="text-lg font-bold mb-6" style="color: var(--color-text-primary);">
          <span class="mr-1" style="color: #e94560;">|</span>関連記事
        </h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {relatedPosts.map((rp) => {
            const rpCat = categories[rp.data.category];
            return (
              <ArticleCard
                href={`/blog/${rp.id}/`}
                title={rp.data.title}
                date={rp.data.date}
                eyecatch={rp.data.eyecatch}
                categoryName={rpCat?.name}
                categoryColor={rpCat?.color}
              />
            );
          })}
        </div>
      </div>
    </section>
  )}
</BaseLayout>
