---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ArticleCard from "../../components/ArticleCard.astro";
import { getCollection } from "astro:content";

const categories = [
  { slug: "all", name: "すべて", color: "#e94560" },
  { slug: "gadget", name: "ガジェット", color: "#e94560" },
  { slug: "creditcard", name: "クレジットカード", color: "#2196F3" },
  { slug: "desk-setup", name: "デスクセットアップ", color: "#4ECDC4" },
  { slug: "dev-env", name: "開発環境", color: "#7B2FBE" },
];

const categoryColors: Record<string, string> = {
  gadget: "#e94560",
  creditcard: "#2196F3",
  "desk-setup": "#4ECDC4",
  "dev-env": "#7B2FBE",
};

const allPosts = await getCollection("posts");
const posts = allPosts.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<BaseLayout title="記事一覧" description="CoreSignalの記事一覧ページ。ガジェット、クレジットカード、デスクセットアップ、開発環境に関する記事をお届けします。">
  <div class="max-w-6xl mx-auto px-4 py-8">
    <h1 class="text-2xl font-bold mb-6" style="color: var(--color-text-primary);">記事一覧</h1>

    {/* カテゴリフィルタータブ */}
    <div class="flex flex-wrap gap-2 mb-8" id="category-tabs">
      {categories.map((cat) => (
        <button
          class="category-tab px-4 py-2 text-sm font-medium rounded-lg border transition-all duration-200"
          data-category={cat.slug}
          style={`border-color: var(--color-border); color: var(--color-text-secondary); background-color: var(--color-surface);`}
        >
          {cat.name}
        </button>
      ))}
    </div>

    {/* 記事グリッド */}
    {posts.length > 0 ? (
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5" id="articles-grid">
        {posts.map((post) => {
          const catName = categories.find((c) => c.slug === post.data.category)?.name;
          const catColor = categoryColors[post.data.category];
          return (
            <div data-post-category={post.data.category}>
              <ArticleCard
                href={`/blog/${post.id}/`}
                title={post.data.title}
                date={post.data.date}
                eyecatch={post.data.eyecatch}
                categoryName={catName}
                categoryColor={catColor}
              />
            </div>
          );
        })}
      </div>
    ) : (
      <p style="color: var(--color-text-muted);">まだ記事がありません。</p>
    )}
  </div>
</BaseLayout>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>(".category-tab");
  const posts = document.querySelectorAll<HTMLElement>("[data-post-category]");

  function setActive(slug: string) {
    tabs.forEach((tab) => {
      const isActive = tab.dataset.category === slug;
      tab.style.backgroundColor = isActive ? "#e94560" : "";
      tab.style.color = isActive ? "#ffffff" : "";
      tab.style.borderColor = isActive ? "#e94560" : "";
    });

    posts.forEach((post) => {
      if (slug === "all" || post.dataset.postCategory === slug) {
        post.style.display = "";
      } else {
        post.style.display = "none";
      }
    });
  }

  // URLパラメータからカテゴリを取得
  const params = new URLSearchParams(window.location.search);
  const initialCategory = params.get("category") || "all";
  setActive(initialCategory);

  tabs.forEach((tab) => {
    tab.addEventListener("click", () => {
      const slug = tab.dataset.category || "all";
      setActive(slug);
      const url = new URL(window.location.href);
      if (slug === "all") {
        url.searchParams.delete("category");
      } else {
        url.searchParams.set("category", slug);
      }
      window.history.replaceState({}, "", url.toString());
    });
  });
</script>
