---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const categories = [
  { slug: "gadget", name: "ガジェット", color: "#e94560" },
  { slug: "creditcard", name: "クレジットカード", color: "#2196F3" },
  { slug: "desk-setup", name: "デスクセットアップ", color: "#4ECDC4" },
  { slug: "dev-env", name: "開発環境", color: "#7B2FBE" },
];

const allPosts = await getCollection("posts");
const posts = allPosts.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<BaseLayout title="記事一覧" description="CoreSignalの記事一覧ページ。ガジェット、クレジットカード、デスクセットアップ、開発環境に関する記事をお届けします。">
  <h1 class="text-3xl font-bold mb-8">記事一覧</h1>

  {posts.length > 0 ? (
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {posts.map((post) => {
        const cat = categories.find((c) => c.slug === post.data.category);
        return (
          <a href={`/blog/${post.id}/`} class="bg-bg-card border border-border rounded-lg overflow-hidden hover:bg-bg-hover transition-colors group">
            <img
              src={post.data.eyecatch}
              alt={`${post.data.title}のアイキャッチ画像`}
              class="w-full h-40 object-cover"
              loading="lazy"
            />
            <div class="p-4">
              {cat && (
                <span class="text-xs font-medium px-2 py-1 rounded" style={`color: ${cat.color}; background: ${cat.color}20`}>
                  {cat.name}
                </span>
              )}
              <h3 class="text-base font-semibold mt-2 group-hover:text-primary transition-colors">
                {post.data.title}
              </h3>
              <p class="text-text-muted text-sm mt-1 line-clamp-2">{post.data.description}</p>
              <time class="text-text-muted text-xs mt-2 block">{post.data.date}</time>
            </div>
          </a>
        );
      })}
    </div>
  ) : (
    <p class="text-text-muted">まだ記事がありません。</p>
  )}
</BaseLayout>
