---
import BaseLayout from "../layouts/BaseLayout.astro";
import ArticleCard from "../components/ArticleCard.astro";
import { getCollection } from "astro:content";
import { CATEGORIES, CATEGORY_MAP, getPostUrl } from "../lib/categories";

const allPosts = await getCollection("posts");
const sortedPosts = allPosts.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

// 【今のおすすめ TOP 5】GA4/GSC データをもとに月次で手動更新推奨
// 選定基準：PV or CTR が高い、収益源となる、季節性のあるもの
const FEATURED_SLUGS = [
  "creditcard/paypay-card-june-alternatives",
  "gadget/anker-prime-power-bank-300w",
  "creditcard/mileageplus-jcb-plat",
  "gadget/mac-mini-m5-wwdc",
  "gadget/pixel-10a-japan",
];
const featuredPosts = FEATURED_SLUGS
  .map((slug) => allPosts.find((p) => p.id === slug || p.id === slug + ".mdx"))
  .filter((p): p is NonNullable<typeof p> => p !== undefined);

const featuredPost = sortedPosts[0];
const featuredCat = featuredPost
  ? CATEGORY_MAP[featuredPost.data.category]
  : null;

const gridPosts = sortedPosts.slice(1, 10);

// 各カテゴリの最新3記事
const categoryPreview = CATEGORIES.map((cat) => ({
  ...cat,
  posts: sortedPosts.filter((p) => p.data.category === cat.slug).slice(0, 3),
}));
---

<BaseLayout
  title="CoreSignal"
  description="ガジェット×クレカの情報メディア。最新ガジェットレビュー、お得なクレジットカード活用術、デスク環境の構築ノウハウをお届けします。"
>
  {/* ヒーローセクション */}
  {featuredPost ? (
    <section class="max-w-6xl mx-auto px-4 pt-8 pb-12">
      <a
        href={getPostUrl(featuredPost)}
        class="group block relative rounded-2xl overflow-hidden border transition-all duration-300"
        style="background-color: var(--color-surface); border-color: var(--color-border);"
      >
        <div class="md:flex">
          <div class="md:w-3/5 relative overflow-hidden">
            <img
              src={featuredPost.data.eyecatch}
              alt={`${featuredPost.data.title}のアイキャッチ画像`}
              class="w-full h-64 md:h-96 object-cover group-hover:scale-105 transition-transform duration-500"
            />
          </div>
          <div class="md:w-2/5 p-6 md:p-8 flex flex-col justify-center">
            <div class="flex items-center gap-3 mb-4">
              {featuredCat && (
                <span
                  class="text-xs font-bold px-3 py-1 rounded-md"
                  style={`color: ${featuredCat.color}; background: ${featuredCat.color}18; border: 1px solid ${featuredCat.color}40;`}
                >
                  {featuredCat.name}
                </span>
              )}
              <span
                class="text-xs font-bold px-3 py-1 rounded-md text-white"
                style="background-color: #e94560;"
              >
                FEATURED
              </span>
            </div>
            <h2
              class="text-xl md:text-2xl font-bold leading-tight transition-colors"
              style="color: var(--color-text-primary);"
            >
              {featuredPost.data.title}
            </h2>
            <p class="text-sm mt-3 line-clamp-2" style="color: var(--color-text-secondary);">
              {featuredPost.data.description}
            </p>
            <div class="flex items-center justify-between mt-4">
              <time class="text-xs" style="color: var(--color-text-muted);">
                {featuredPost.data.date.slice(0, 10)}
              </time>
              <span class="text-sm font-medium" style="color: #e94560;">
                続きを読む &rarr;
              </span>
            </div>
          </div>
        </div>
      </a>
    </section>
  ) : (
    <section class="max-w-6xl mx-auto px-4 pt-16 pb-12 text-center">
      <h1 class="text-4xl md:text-5xl font-black tracking-tight mb-4">
        <span class="bg-gradient-to-r from-accent-blue to-accent-purple bg-clip-text text-transparent">Core</span><span style="color: var(--color-text-primary);">Signal</span>
      </h1>
      <p class="text-lg max-w-2xl mx-auto" style="color: var(--color-text-secondary);">
        ガジェット×クレカの情報メディア。<br />
        最新ガジェットレビュー、お得なクレジットカード活用術、デスク環境の構築ノウハウをお届けします。
      </p>
    </section>
  )}

  {/* 【新設】今のおすすめ セクション */}
  {featuredPosts.length > 0 && (
    <section class="max-w-6xl mx-auto px-4 pb-12">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-lg font-bold" style="color: var(--color-text-primary);">
          <span class="mr-1" style="color: #e94560;">|</span>今のおすすめ
        </h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4">
        {featuredPosts.map((post) => {
          const cat = CATEGORY_MAP[post.data.category];
          return (
            <ArticleCard
              href={getPostUrl(post)}
              title={post.data.title}
              date={post.data.date}
              eyecatch={post.data.eyecatch}
              categoryName={cat?.name}
              categoryColor={cat?.color}
            />
          );
        })}
      </div>
    </section>
  )}

  {/* 最新記事グリッド */}
  {gridPosts.length > 0 && (
    <section class="max-w-6xl mx-auto px-4 pb-12">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-lg font-bold" style="color: var(--color-text-primary);">
          <span class="mr-1" style="color: #e94560;">|</span>最新記事
        </h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {gridPosts.map((post) => {
          const cat = CATEGORY_MAP[post.data.category];
          return (
            <ArticleCard
              href={getPostUrl(post)}
              title={post.data.title}
              date={post.data.date}
              eyecatch={post.data.eyecatch}
              categoryName={cat?.name}
              categoryColor={cat?.color}
            />
          );
        })}
      </div>
    </section>
  )}

  {/* 【拡張】カテゴリセクション：各カテゴリのプレビュー付き */}
  <section class="max-w-6xl mx-auto px-4 pb-12">
    <h2 class="text-lg font-bold mb-6" style="color: var(--color-text-primary);">
      <span class="mr-1" style="color: #e94560;">|</span>カテゴリ
    </h2>
    <div class="grid md:grid-cols-2 gap-5">
      {categoryPreview.map((cat) => (
        <div
          class="rounded-xl border p-5"
          style={`background-color: var(--color-surface); border-color: var(--color-border); border-top: 3px solid ${cat.color};`}
        >
          <div class="flex items-center justify-between mb-4">
            <h3 class="text-base font-bold" style={`color: ${cat.color};`}>
              {cat.name}
            </h3>
            <a
              href={`/${cat.slug}/`}
              class="text-xs font-medium transition-opacity hover:opacity-70"
              style={`color: ${cat.color};`}
            >
              すべて見る →
            </a>
          </div>
          <div class="space-y-3">
            {cat.posts.map((p) => (
              <a
                href={getPostUrl(p)}
                class="block text-sm transition-colors hover:opacity-80"
                style="color: var(--color-text-secondary); line-height: 1.5;"
              >
                {p.data.title}
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  {/* 【新設】書き手紹介ボックス（E-E-A-T シグナル + about 導線）*/}
  <section class="max-w-4xl mx-auto px-4 pb-20">
    <div
      class="rounded-xl border p-6"
      style="background-color: var(--color-bg-secondary); border-color: var(--color-border);"
    >
      <div class="flex flex-col sm:flex-row items-start gap-5">
        <div class="shrink-0 self-center sm:self-start">
          <img
            src="/images/site/profile.png"
            alt="ナナ（CoreSignal 編集長）"
            class="rounded-full"
            width="80"
            height="80"
            style="object-fit: cover; border: 2px solid var(--color-border);"
          />
        </div>
        <div class="flex-1 space-y-2">
          <div>
            <p class="text-base font-bold mb-0" style="color: var(--color-text-primary);">
              ナナ｜CoreSignal 編集長
            </p>
            <p class="text-xs mt-1 mb-0" style="color: var(--color-text-muted);">
              インフラエンジニア（AWS・Linux・コンテナ）
            </p>
          </div>
          <p class="text-sm" style="color: var(--color-text-secondary); line-height: 1.7;">
            仕事で使うツールをスペック比較表にまとめて判断基準を整理する癖から生まれた「判断基準を整理するメディア」。ガジェットとクレカを中心に、公式情報のみで事実整理型の記事を書いています。
          </p>
          <a
            href="/about/"
            class="inline-block text-xs font-medium mt-1 transition-opacity hover:opacity-70"
            style="color: #7B2FBE;"
          >
            プロフィール詳細 →
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
