---
import BaseLayout from "../layouts/BaseLayout.astro";
import ArticleCard from "../components/ArticleCard.astro";
import { getCollection } from "astro:content";
import { CATEGORIES, CATEGORY_MAP, getPostUrl } from "../lib/categories";

const allPosts = await getCollection("posts");
const sortedPosts = allPosts.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const featuredPost = sortedPosts[0];
const featuredCat = featuredPost
  ? CATEGORY_MAP[featuredPost.data.category]
  : null;

const gridPosts = sortedPosts.slice(1, 9);
---

<BaseLayout
  title="CoreSignal"
  description="ガジェット×クレカの情報メディア。最新ガジェットレビュー、お得なクレジットカード活用術、デスク環境の構築ノウハウをお届けします。"
>
  {/* ヒーローセクション */}
  {featuredPost ? (
    <section class="max-w-6xl mx-auto px-4 pt-8 pb-12">
      <a
        href={getPostUrl(featuredPost)}
        class="group block relative rounded-2xl overflow-hidden border transition-all duration-300"
        style="background-color: var(--color-surface); border-color: var(--color-border);"
      >
        <div class="md:flex">
          <div class="md:w-3/5 relative overflow-hidden">
            <img
              src={featuredPost.data.eyecatch}
              alt={`${featuredPost.data.title}のアイキャッチ画像`}
              class="w-full h-64 md:h-96 object-cover group-hover:scale-105 transition-transform duration-500"
            />
          </div>
          <div class="md:w-2/5 p-6 md:p-8 flex flex-col justify-center">
            <div class="flex items-center gap-3 mb-4">
              {featuredCat && (
                <span
                  class="text-xs font-bold px-3 py-1 rounded-md"
                  style={`color: ${featuredCat.color}; background: ${featuredCat.color}18; border: 1px solid ${featuredCat.color}40;`}
                >
                  {featuredCat.name}
                </span>
              )}
              <span
                class="text-xs font-bold px-3 py-1 rounded-md text-white"
                style="background-color: #e94560;"
              >
                FEATURED
              </span>
            </div>
            <h2
              class="text-xl md:text-2xl font-bold leading-tight transition-colors"
              style="color: var(--color-text-primary);"
            >
              {featuredPost.data.title}
            </h2>
            <p class="text-sm mt-3 line-clamp-2" style="color: var(--color-text-secondary);">
              {featuredPost.data.description}
            </p>
            <div class="flex items-center justify-between mt-4">
              <time class="text-xs" style="color: var(--color-text-muted);">
                {featuredPost.data.date}
              </time>
              <span class="text-sm font-medium" style="color: #e94560;">
                続きを読む &rarr;
              </span>
            </div>
          </div>
        </div>
      </a>
    </section>
  ) : (
    <section class="max-w-6xl mx-auto px-4 pt-16 pb-12 text-center">
      <h1 class="text-4xl md:text-5xl font-black tracking-tight mb-4">
        <span style="color: #e94560;">Core</span><span style="color: var(--color-text-primary);">Signal</span>
      </h1>
      <p class="text-lg max-w-2xl mx-auto" style="color: var(--color-text-secondary);">
        ガジェット×クレカの情報メディア。<br />
        最新ガジェットレビュー、お得なクレジットカード活用術、デスク環境の構築ノウハウをお届けします。
      </p>
    </section>
  )}

  {/* 最新記事グリッド */}
  {gridPosts.length > 0 && (
    <section class="max-w-6xl mx-auto px-4 pb-16">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-lg font-bold" style="color: var(--color-text-primary);">
          <span class="mr-1" style="color: #e94560;">|</span>最新記事
        </h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {gridPosts.map((post) => {
          const cat = CATEGORY_MAP[post.data.category];
          return (
            <ArticleCard
              href={getPostUrl(post)}
              title={post.data.title}
              date={post.data.date}
              eyecatch={post.data.eyecatch}
              categoryName={cat?.name}
              categoryColor={cat?.color}
            />
          );
        })}
      </div>
    </section>
  )}

  {/* カテゴリセクション */}
  <section class="max-w-6xl mx-auto px-4 pb-20">
    <h2 class="text-lg font-bold mb-6" style="color: var(--color-text-primary);">
      <span class="mr-1" style="color: #e94560;">|</span>カテゴリ
    </h2>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      {CATEGORIES.map((cat) => (
        <a
          href={`/${cat.slug}/`}
          class="group relative rounded-xl border p-5 text-center transition-all duration-300 overflow-hidden"
          style={`background-color: var(--color-surface); border-color: var(--color-border);`}
        >
          <div
            class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-300"
            style={`background: linear-gradient(135deg, ${cat.color}08, ${cat.color}15);`}
          />
          <span class="relative text-base font-bold" style={`color: ${cat.color};`}>
            {cat.name}
          </span>
          <div
            class="absolute bottom-0 left-0 right-0 h-0.5 scale-x-0 group-hover:scale-x-100 transition-transform duration-300"
            style={`background: ${cat.color};`}
          />
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
